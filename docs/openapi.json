{"openapi":"3.0.0","info":{"title":"Desafio Técnico API","description":"API de rastreamento de agentes em tempo real com integração incremental à API externa. Suporta sincronização de agentes, localizações, check-ins e geofences com resiliência a falhas.","version":"0.1.0"},"components":{"schemas":{}},"paths":{"/health":{"get":{"summary":"Status da API","tags":["saude"],"description":"Verifica se a API está operacional e retorna o horário atual do servidor.","responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"status":{"type":"string","description":"Estado da API"},"timestamp":{"type":"string","description":"Data e hora atual do servidor (ISO 8601)"}},"required":["status","timestamp"],"additionalProperties":false}}}}}}},"/api/v1/agents/":{"get":{"summary":"Listar agentes","tags":["agentes"],"description":"Retorna todos os agentes cadastrados, ordenados por nome. Use `active=false` para incluir agentes inativos.","parameters":[{"schema":{"type":"string","enum":["true","false"]},"in":"query","name":"active","required":false,"description":"Filtra por status ativo/inativo"}],"responses":{"200":{"description":"Lista de agentes","content":{"application/json":{"schema":{"type":"object","properties":{"data":{"type":"array","items":{"type":"object","properties":{"id":{"type":"string","description":"ID interno do agente"},"externalId":{"type":"string","description":"ID do agente na API externa"},"name":{"type":"string","description":"Nome do agente"},"role":{"type":"string","enum":["TECHNICIAN","MAINTENANCE","VENDOR","INSTALLER"],"nullable":true,"description":"Função do agente"},"team":{"type":"string","nullable":true,"description":"Equipe do agente"},"phone":{"type":"string","nullable":true,"description":"Telefone de contato"},"email":{"type":"string","nullable":true,"description":"E-mail de contato"},"active":{"type":"boolean","description":"Indica se o agente está ativo"},"status":{"type":"string","enu