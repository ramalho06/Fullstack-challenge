lable":true,"description":"Equipe do agente"},"phone":{"type":"string","nullable":true,"description":"Telefone de contato"},"email":{"type":"string","nullable":true,"description":"E-mail de contato"},"active":{"type":"boolean","description":"Indica se o agente está ativo"},"status":{"type":"string","enum":["ONLINE","PAUSED","SIGNAL_LOST","OFFLINE"],"description":"Status atual do agente"},"battery":{"type":"number","nullable":true,"description":"Nível de bateria do dispositivo (%)"},"lastSeen":{"type":"string","nullable":true,"description":"Última vez visto (ISO 8601)"},"createdAt":{"type":"string","description":"Data de criação (ISO 8601)"},"updatedAt":{"type":"string","description":"Data da última atualização (ISO 8601)"}},"required":["id","externalId","name","role","team","phone","email","active","status","battery","lastSeen","createdAt","updatedAt"],"additionalProperties":false}},"required":["data"],"additionalProperties":false,"description":"Dados do agente"}}}},"404":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/agents/{id}/location":{"get":{"summary":"Localização atual do agente","tags":["agentes"],"description":"Retorna a última localização conhecida de um agente, incluindo acurácia GPS, velocidade e bateria. Leituras com acurácia superior a 50 metros são descartadas durante a sincronização.","parameters":[{"schema":{"type":"string"},"in":"path","name":"id","required":true,"description":"ID interno do agente"}],"responses":{"200":{"description":"Dados de localização do agente","content":{"application/json":{"schema":{"type":"object","properties":{"data":{"type":"object","properties":{"agentId":{"type":"string","description":"ID interno do agente"},"externalId":{"type":"string","description":"ID do agente na API externa"},"latitude":{"type":"number","nullable":true,"description":"Latitude em graus decimais"},"longitude":{"type":"number","nullable":true,"description":"Longitude em graus decimais"},"currentAddress":{"type":"string","nullable":true,"description":"Endereço atual estimado"},"accuracy":{"type":"number","nullable":true,"description":"Acurácia GPS em metros"},"speed":{"type":"number","nullable":true,"description":"Velocidade em km/h"},"battery":{"type":"number","nullable":true,"description":"Nível de bateria (%)"},"status":{"type":"string","enum":["ONLINE","PAUSED","SIGNAL_LOST","OFFLINE"],"description":"Status do agente"},"lastSeen":{"type":"string","nullable":true,"description":"Último sinal recebido (ISO 8601)"}},"required":["agentId","externalId","latitude","longitude","currentAddress","accuracy","speed","battery","status","lastSeen"],"additionalProperties":false}},"required":["data"],"additionalProperties":false,"description":"Dados de localização do agente"}}}},"404":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/agents/{id}/route":{"get":{"summary":"Percurso do agente em uma data","tags":["agentes"],"description":"Retorna o percurso completo (sequência de pontos GPS) de um agente em uma data específica. Consulta o cache local antes de acionar a API externa. Pontos com acurácia GPS superior a 50 metros são excluídos automaticamente.","parameters":[{"schema":{"type":"string","pattern":"^\\d{4}-\\d{2}-\\d{2}$"},"in":"query","name":"date","required":true,"description":"Data do percurso no formato YYYY-MM-DD"},{"schema":{"type":"string"},"in":"path","name":"id","required":true,"description":"ID interno do agente"}],"responses":{"200":{"description":"Default Response","content":{"application/json":{"schema":{"type":"object","properties":{"data":{"type":"object","properties":{"agentId":{"type":"string"},"date":{"type":"string","description":"Data do percurso (YYYY-MM-DD)"},"points":{"type":"array","items":{"type":"object","properties":{"latitude":{"type":"number","description":"Latitude"},"longitude":{"type":"number","description":"Longitude"},"accuracy":{"type":"number","nullable":true,"description":"Acurácia GPS em metros"},"timestamp":{"type":"string","description":"Data e hora do ponto (ISO 8601)"}},"required":["latitude","longitude","accuracy","timestamp"],"additionalProperties":false},"description":"Pontos GPS ordenados por horário"}},"required":["agentId","date","points"],"additionalProperties":false}},"required":["data"],"additionalProperties":false}}}},"404":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"422":{"description":"Resposta de erro de validação de campos","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","enum":["VALIDATION_ERROR"]},"message":{"type":"string","description":"Mensagem do erro de validação"},"issues":{"type":"array","items":{"type":"object","properties":{"path":{"type":"array","items":{"type":"string"}},"message":{"type":"string"}},"required":["path","message"],"additionalProperties":false},"description":"Lista detalhada dos campos e regras violadas"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro de validação de campos"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"502":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/locations/":{"get":{"summary":"Listar localizações atuais","tags":["localizacoes"],"description":"Retorna a posição geográfica mais recente de todos os agentes ativos. Os dados de localização são embutidos no cadastro do agente e atualizados a cada sincronização. Leituras com acurácia GPS superior a 50 metros são descartadas pelo sincronizador.","parameters":[{"schema":{"type":"string","enum":["true","false"]},"in":"query","name":"onlineOnly","required":false,"description":"Se \"true\", retorna apenas agentes com status ONLINE"}],"responses":{"200":{"description":"Localizações atuais dos agentes","content":{"application/json":{"schema":{"type":"object","properties":{"data":{"type":"array","items":{"type":"object","properties":{"agentId":{"type":"string","description":"ID interno do agente"},"externalId":{"type":"string","description":"ID do agente na API externa"},"name":{"type":"string","description":"Nome do agente"},"latitude":{"type":"number","nullable":true,"description":"Latitude em graus decimais"},"longitude":{"type":"number","nullable":true,"description":"Longitude em graus decimais"},"currentAddress":{"type":"string","nullable":true,"description":"Endereço atual estimado"},"accuracy":{"type":"number","nullable":true,"description":"Acurácia GPS em metros"},"speed":{"type":"number","nullable":true,"description":"Velocidade em km/h"},"battery":{"type":"number","nullable":true,"description":"Nível de bateria (%)"},"status":{"type":"string","enum":["ONLINE","PAUSED","SIGNAL_LOST","OFFLINE"],"description":"Status de conectividade"},"lastSeen":{"type":"string","nullable":true,"description":"Último sinal recebido (ISO 8601)"}},"required":["agentId","externalId","name","latitude","longitude","currentAddress","accuracy","speed","battery","status","lastSeen"],"additionalProperties":false}}},"required":["data"],"additionalProperties":false,"description":"Localizações atuais dos agentes"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/check-ins/":{"get":{"summary":"Listar check-ins","tags":["check-ins"],"description":"Retorna os check-ins registrados, ordenados por data de ocorrência. Filtre por agente (`agentId`) e/ou por tipo (`type`).","parameters":[{"schema":{"type":"string"},"in":"query","name":"agentId","required":false,"description":"Filtra check-ins de um agente específico"},{"schema":{"type":"string","enum":["CHECKIN","CHECKOUT","VISIT_COMPLETED","STOP_DETECTED","STOP_ENDED","SIGNAL_LOST","SIGNAL_RESTORED","LOW_BATTERY","GEOFENCE_ENTER","GEOFENCE_EXIT"]},"in":"query","name":"type","required":false,"description":"Filtra por tipo de check-in"}],"responses":{"200":{"description":"Lista de check-ins","content":{"application/json":{"schema":{"type":"object","properties":{"data":{"type":"array","items":{"type":"object","properties":{"id":{"type":"string","description":"ID interno do check-in"},"agentId":{"type":"string","description":"ID interno do agente"},"type":{"type":"string","enum":["CHECKIN","CHECKOUT","VISIT_COMPLETED","STOP_DETECTED","STOP_ENDED","SIGNAL_LOST","SIGNAL_RESTORED","LOW_BATTERY","GEOFENCE_ENTER","GEOFENCE_EXIT"],"description":"Tipo do check-in"},"source":{"type":"string","enum":["MANUAL","GPS_SYNC","EVENT_SYNC"],"description":"Origem do registro: manual, GPS ou evento externo"},"latitude":{"type":"number","nullable":true,"description":"Latitude do check-in"},"longitude":{"type":"number","nullable":true,"description":"Longitude do check-in"},"address":{"type":"string","nullable":true,"description":"Endereço no momento do check-in"},"accuracy":{"type":"number","nullable":true,"description":"Acurácia GPS em metros"},"speed":{"type":"number","nullable":true,"description":"Velocidade em km/h no momento do check-in"},"notes":{"type":"string","nullable":true,"description":"Observações adicionais"},"distanceFromPrevious":{"type":"number","nullable":true,"description":"Distância do check-in anterior (metros)"},"externalEventId":{"type":"string","nullable":true,"description":"ID do evento na API externa"},"occurredAt":{"type":"string","description":"Data e hora em que o evento ocorreu (ISO 8601)"},"syncedAt":{"type":"string","description":"Data e hora em que foi sincronizado (ISO 8601)"}},"required":["id","agentId","type","source","latitude","longitude","address","accuracy","speed","notes","distanceFromPrevious","externalEventId","occurredAt","syncedAt"],"additionalProperties":false}}},"required":["data"],"additionalProperties":false,"description":"Lista de check-ins"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/geofences/":{"get":{"summary":"Listar geofences","tags":["geofences"],"description":"Retorna todas as cercas geográficas virtuais cadastradas. O campo `coordinatesJson` contém as coordenadas no formato GeoJSON. O tipo pode ser `POLYGON` (área fechada) ou `CIRCLE` (raio a partir de um ponto).","responses":{"200":{"description":"Lista de geofences","content":{"application/json":{"schema":{"type":"object","properties":{"data":{"type":"array","items":{"type":"object","properties":{"id":{"type":"string","description":"ID interno da geofence"},"externalId":{"type":"string","description":"ID da geofence na API externa"},"name":{"type":"string","description":"Nome descritivo da geofence"},"type":{"type":"string","enum":["POLYGON","CIRCLE"],"description":"Tipo da geometria"},"coordinatesJson":{"type":"string","description":"Coordenadas em formato JSON (GeoJSON)"},"alertOnEnter":{"type":"boolean","description":"Emitir alerta ao entrar na geofence"},"alertOnExit":{"type":"boolean","description":"Emitir alerta ao sair da geofence"},"assignedTeams":{"type":"string","nullable":true,"description":"Equipes associadas à geofence"},"syncedAt":{"type":"string","description":"Data da última sincronização (ISO 8601)"}},"required":["id","externalId","name","type","coordinatesJson","alertOnEnter","alertOnExit","assignedTeams","syncedAt"],"additionalProperties":false}}},"required":["data"],"additionalProperties":false,"description":"Lista de geofences"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/sync/agents":{"post":{"summary":"Sincronizar agentes","tags":["sincronizacao"],"description":"Busca todos os agentes da API externa e atualiza o banco via upsert pelo `externalId`. Campos sincronizados: nome, função (role), equipe, telefone, e-mail e status ativo. Realiza paginação automática (máx. 50 registros por página). Em erro 429, aguarda o tempo indicado pelo cabeçalho `Retry-After`. Em erro 503, aplica backoff exponencial com jitter.","responses":{"200":{"description":"Resultado da sincronização","content":{"application/json":{"schema":{"type":"object","properties":{"synced":{"type":"number","description":"Quantidade de registros sincronizados"}},"required":["synced"],"additionalProperties":false,"description":"Resultado da sincronização"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"502":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/sync/locations":{"post":{"summary":"Sincronizar localizações dos agentes","tags":["sincronizacao"],"description":"Sincroniza as localizações atuais de todos os agentes com a API externa. Atualiza diretamente os campos de localização no cadastro do agente: latitude, longitude, endereço, acurácia, velocidade, bateria e status. Leituras GPS com acurácia superior a 50 metros são descartadas antes de persistir.","responses":{"200":{"description":"Resultado da sincronização","content":{"application/json":{"schema":{"type":"object","properties":{"synced":{"type":"number","description":"Quantidade de registros sincronizados"}},"required":["synced"],"additionalProperties":false,"description":"Resultado da sincronização"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"502":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/sync/check-ins":{"post":{"summary":"Sincronizar check-ins (incremental)","tags":["sincronizacao"],"description":"Sincroniza check-ins de forma incremental usando o `syncToken` da última execução bem-sucedida. Na primeira execução, busca todos os eventos disponíveis. Nas chamadas seguintes, retorna apenas os eventos novos. Eventos da API externa são mapeados para tipos de check-in: `check_in` → CHECKIN, `stop_detected` → STOP_DETECTED, `geofence_enter` → GEOFENCE_ENTER, etc. O token é persistido em `SyncExecution` ao final de cada sincronização.","responses":{"200":{"description":"Resultado da sincronização incremental","content":{"application/json":{"schema":{"type":"object","properties":{"synced":{"type":"number","description":"Novos check-ins registrados"},"syncToken":{"type":"string","description":"Token atualizado para a próxima sincronização"}},"required":["synced","syncToken"],"additionalProperties":false,"description":"Resultado da sincronização incremental"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"502":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/sync/geofences":{"post":{"summary":"Sincronizar geofences","tags":["sincronizacao"],"description":"Busca todas as geofences da API externa e atualiza o banco via upsert pelo `externalId`. Campos sincronizados: nome, tipo (POLYGON/CIRCLE), coordenadas, alertas de entrada/saída e equipes.","responses":{"200":{"description":"Resultado da sincronização","content":{"application/json":{"schema":{"type":"object","properties":{"synced":{"type":"number","description":"Quantidade de registros sincronizados"}},"required":["synced"],"additionalProperties":false,"description":"Resultado da sincronização"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"502":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}},"/api/v1/sync/all":{"post":{"summary":"Sincronização completa","tags":["sincronizacao"],"description":"Executa agentes, localizações, check-ins e geofences em paralelo. Se qualquer sincronização falhar, o erro é propagado; as demais podem ter concluído.","responses":{"200":{"description":"Totais por entidade","content":{"application/json":{"schema":{"type":"object","properties":{"agents":{"type":"number","description":"Agentes sincronizados"},"locations":{"type":"number","description":"Localizações atualizadas"},"checkIns":{"type":"number","description":"Check-ins sincronizados"},"geofences":{"type":"number","description":"Geofences sincronizadas"}},"required":["agents","locations","checkIns","geofences"],"additionalProperties":false,"description":"Totais por entidade"}}}},"500":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}},"502":{"description":"Resposta de erro padrão","content":{"application/json":{"schema":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"string","description":"Código de erro interno"},"message":{"type":"string","description":"Descrição legível do erro"},"details":{"type":"string","description":"Informações adicionais sobre o erro"}},"required":["code","message"],"additionalProperties":false}},"required":["error"],"additionalProperties":false,"description":"Resposta de erro padrão"}}}}}}}},"tags":[{"name":"saude","description":"Verificação de disponibilidade da API"},{"name":"agentes","description":"Consulta e rastreamento de agentes registrados"},{"name":"localizacoes","description":"Posições geográficas atuais dos agentes"},{"name":"check-ins","description":"Check-ins e eventos gerados pelos agentes em campo"},{"name":"geofences","description":"Cercas geográficas virtuais cadastradas"},{"name":"sincronizacao","description":"Gatilhos de sincronização com a API externa"}]}
