# ===========================================
# Variáveis de Ambiente - Teams Tracking System
# ===========================================
# Copie este arquivo para .env e preencha com seus valores reais:
#   cp .env.example .env
#
# IMPORTANTE: O arquivo .env NUNCA deve ser commitado no Git.
# Ele já está incluído no .gitignore.
# ===========================================

# ---------- MySQL (Docker Compose) ----------
MYSQL_DATABASE=challenge
MYSQL_USER=trackinguser
MYSQL_PASSWORD=trackingpass
MYSQL_ROOT_PASSWORD=rootroot

# ---------- Spring Boot (Backend) ----------
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/challenge
SPRING_DATASOURCE_USERNAME=trackinguser
SPRING_DATASOURCE_PASSWORD=trackingpass

# Observação:
# - Em execução local fora do Docker, use localhost na SPRING_DATASOURCE_URL.
# - No docker-compose, o serviço backend sobrescreve essa URL para usar o hostname mysql.

# ---------- API Externa (GPS) ----------
EXTERNAL_API_BASE_URL=https://desafio-media.onrender.com
EXTERNAL_API_KEY=sua_api_key_aqui

# ---------- Schedulers ----------
# true mantém os 4 schedulers obrigatórios ativos.
# Use false em desenvolvimento quando quiser testar apenas endpoints manuais.
APP_SCHEDULERS_ENABLED=true

# ---------- Frontend / CORS ----------
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
